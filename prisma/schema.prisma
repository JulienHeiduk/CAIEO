generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String             @id @default(cuid())
  clerkId           String             @unique
  email             String             @unique
  name              String?
  createdAt         DateTime           @default(now())
  companies         Company[]
  socialCredentials SocialCredential[]
  settings          UserSettings?
  gitHubBootstraps  GitHubBootstrap[]
  repoSessions      RepoSession[]
  autopilotRuns     AutopilotRun[]
}

model RepoSession {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  repoPath       String
  repoUrl        String?
  repoName       String
  isOwner        Boolean    @default(true)
  contextSummary String?
  contextStatus  String     @default("PENDING")
  currentCycle   Int        @default(1)
  status         String     @default("ACTIVE")
  reviewContent  String?
  reviewLog      String?
  reviewStatus   String     @default("IDLE")
  reviewCycle    Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  repoTasks      RepoTask[]

  @@index([userId])
}

model RepoTask {
  id                String      @id @default(cuid())
  sessionId         String
  session           RepoSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  cycle             Int
  number            Int
  title             String
  description       String
  priority          String      @default("medium")
  estimate          String?
  affectedFiles     String?
  status            String      @default("PENDING")
  executionLog      String?
  diff              String?
  commitHash        String?
  userNote          String?
  editedTitle       String?
  editedDescription String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([sessionId])
}

model GitHubBootstrap {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  idea             String
  repoName         String
  visibility       String   @default("private")
  localPath        String
  currentStep      Int      @default(1)
  stepStatus       String   @default("GENERATING")
  stepError        String?
  description      String?
  repoUrl          String?
  repoFullName     String?
  clonedPath       String?
  readmeContent    String?
  changelogContent String?
  tasksContent     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model UserSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])

  // Deployment & Code
  vercelToken       String?
  vercelTeamId      String?
  githubToken       String?

  // Backend & Database
  supabaseToken     String?
  supabaseOrgId     String?

  // Payments
  stripeSecretKey   String?

  // Email
  resendApiKey      String?

  // Auth
  clerkSecretKey    String?

  // Analytics & Monitoring
  posthogApiKey     String?
  posthogHost       String?
  sentryAuthToken   String?
  sentryOrg         String?

  // Vector DB
  pineconeApiKey    String?

  // Social Media
  linkedinToken     String?
  twitterApiKey     String?
  twitterApiSecret  String?
  twitterAccessToken  String?
  twitterAccessSecret String?
  redditClientId    String?
  redditClientSecret String?
  redditUsername     String?
  redditPassword     String?

  updatedAt    DateTime @updatedAt
}

model Company {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  name           String
  slug           String        @unique
  description    String
  ideaPrompt     String
  strategy       String?
  status         CompanyStatus @default(INITIALIZING)
  landingPageUrl String?
  githubRepoUrl  String?
  githubContext  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tasks          Task[]
  activityLogs   ActivityLog[]
  agentRuns      AgentRun[]
  autopilotRuns  AutopilotRun[]

  @@index([userId])
}

enum CompanyStatus {
  INITIALIZING
  ACTIVE
  PAUSED
  ARCHIVED
}

model Task {
  id                String     @id @default(cuid())
  companyId         String
  company           Company    @relation(fields: [companyId], references: [id])
  title             String
  description       String
  agentType         AgentType
  status            TaskStatus @default(PENDING_REVIEW)
  priority          Int        @default(0)
  userNote          String?
  editedTitle       String?
  editedDescription String?
  result            Json?
  errorMessage      String?
  scheduledFor      DateTime?
  approvedAt        DateTime?
  executedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  agentRun          AgentRun?

  @@index([companyId, status])
}

enum TaskStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXECUTING
  COMPLETED
  FAILED
}

enum AgentType {
  LANDING_PAGE
  LINKEDIN_POST
  TWITTER_POST
  REDDIT_POST
  HACKERNEWS_POST
  KAGGLE_POST
  GROWTH_MARKETING
  API_SCAFFOLD
  COMPANY_INIT
  SUPABASE_SETUP
  CLERK_SETUP
  STRIPE_SETUP
  RESEND_SETUP
  POSTHOG_SETUP
  SENTRY_SETUP
  FRONTEND_BUILD
  BACKEND_BUILD
  VERCEL_DEPLOY
  README_UPDATE
}

model ActivityLog {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id])
  agentType AgentType?
  taskId    String?
  eventType String
  summary   String
  detail    Json?
  createdAt DateTime   @default(now())

  @@index([companyId, createdAt])
}

model AgentRun {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  taskId        String?   @unique
  task          Task?     @relation(fields: [taskId], references: [id])
  agentType     AgentType
  inputPayload  Json
  outputPayload Json?
  toolCalls     Json?
  tokensUsed    Int?
  durationMs    Int?
  status        RunStatus @default(RUNNING)
  errorMessage  String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([companyId])
}

enum RunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model SocialCredential {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  platform     SocialPlatform
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, platform])
}

enum SocialPlatform {
  LINKEDIN
  TWITTER
  REDDIT
  HACKERNEWS
  KAGGLE
}

model AutopilotRun {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id])

  currentStep     Int      @default(1)
  stepStatus      String   @default("RUNNING")
  stepError       String?

  emailSubject    String?
  emailBody       String?
  ideaRaw         String?

  isValidSoftware Boolean?
  validationNote  String?

  companyName     String?

  repoUrl         String?
  repoLocalPath   String?

  tasksGenerated  Int?
  tasksCompleted  Int      @default(0)
  tasksTotal      Int      @default(0)
  currentTaskId   String?

  stopRequested   Boolean  @default(false)
  logs            String   @default("[]")

  triggerType     String   @default("MANUAL")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}
